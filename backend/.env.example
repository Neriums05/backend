# Copy this file to .env and fill in your values

# Get this from MongoDB Atlas (free tier is fine)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>

# Any random string - used to sign JWT tokens
JWT_SECRET=some_random_secret_string_here

# Port the backend runs on
PORT=5000

# Admin account - created automatically on first server start
ADMIN_EMAIL=admin@felicity.com
ADMIN_PASSWORD=Admin@123

# Email sending - use a Gmail account with "App Password" enabled
# Go to Google Account > Security > App Passwords to generate one
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Where your frontend runs (for CORS)
FRONTEND_URL=http://localhost:5173
